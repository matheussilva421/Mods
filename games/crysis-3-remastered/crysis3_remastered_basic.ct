  </CheatEntries>
  <UserdefinedSymbols/>
  <LuaScript><![CDATA[
if syntaxcheck then return end

local processName = 'Crysis3Remastered.exe'
local attached = false

if getOpenedProcessID() ~= 0 then
  attached = true
else
  local ok = pcall(openProcess, processName)
  if ok and getOpenedProcessID() ~= 0 then
    attached = true
  end
end

getAutoAttachList().add(processName)

if not attached then
  print('[crysis3 trainer] waiting for process: ' .. processName)
end

if _G.CRYSIS3_PANIC_HK ~= nil then
  CRYSIS3_PANIC_HK.destroy()
  CRYSIS3_PANIC_HK = nil
end

CRYSIS3_PANIC_HK = createHotkey(function()
  local al = getAddressList()
  for i = 0, al.Count - 1 do
    local rec = al[i]
    if rec ~= nil and rec.Active then
      rec.Active = false
    end
  end
  showMessage('Trainer entries disabled.')
end, VK_F12)
  ]]></LuaScript>
</CheatTable>
