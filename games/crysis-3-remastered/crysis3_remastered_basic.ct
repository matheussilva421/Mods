<?xml version="1.0" encoding="utf-8"?>
<CheatTable>
  <CheatEntries>
    <CheatEntry>
      <ID>1</ID>
      <Description>"[F1] Infinite Health (template)"</Description>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript><![CDATA[
[ENABLE]
aobscanmodule(C3R_HEALTH_WRITE,Crysis3Remastered.exe,00 11 22 33 44 55 66 77)
assert(C3R_HEALTH_WRITE,00 11 22 33 44 55 66 77)
alloc(newmem_health,$1000,C3R_HEALTH_WRITE)
label(code_health)
label(return_health)

newmem_health:
  // Template hook: skip the original health write.
  jmp return_health

code_health:
  mov [rbx+000001C0],eax
  jmp return_health

C3R_HEALTH_WRITE:
  jmp newmem_health
  nop
  nop
  nop
return_health:

[DISABLE]
C3R_HEALTH_WRITE:
  db 00 11 22 33 44 55 66 77

dealloc(newmem_health)
      ]]></AssemblerScript>
      <Hotkeys>
        <Hotkey>
          <Action>Toggle Activation</Action>
          <Keys>
            <Key>112</Key>
          </Keys>
          <ID>0</ID>
        </Hotkey>
      </Hotkeys>
    </CheatEntry>
    <CheatEntry>
      <ID>2</ID>
      <Description>"[F2] Infinite Nanosuit Energy (template)"</Description>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript><![CDATA[
[ENABLE]
aobscanmodule(C3R_ENERGY_WRITE,Crysis3Remastered.exe,AA BB CC DD EE FF 00 11)
assert(C3R_ENERGY_WRITE,AA BB CC DD EE FF 00 11)
alloc(newmem_energy,$1000,C3R_ENERGY_WRITE)
label(code_energy)
label(return_energy)

newmem_energy:
  // Template hook: block nanosuit energy drain.
  jmp return_energy

code_energy:
  movss [rcx+000002A0],xmm1
  jmp return_energy

C3R_ENERGY_WRITE:
  jmp newmem_energy
  nop
  nop
  nop
return_energy:

[DISABLE]
C3R_ENERGY_WRITE:
  db AA BB CC DD EE FF 00 11

dealloc(newmem_energy)
      ]]></AssemblerScript>
      <Hotkeys>
        <Hotkey>
          <Action>Toggle Activation</Action>
          <Keys>
            <Key>113</Key>
          </Keys>
          <ID>1</ID>
        </Hotkey>
      </Hotkeys>
    </CheatEntry>
    <CheatEntry>
      <ID>3</ID>
      <Description>"[F3] Infinite Ammo (template)"</Description>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript><![CDATA[
[ENABLE]
aobscanmodule(C3R_AMMO_SUB,Crysis3Remastered.exe,88 99 AA BB CC DD)
assert(C3R_AMMO_SUB,88 99 AA BB CC DD)
alloc(newmem_ammo,$1000,C3R_AMMO_SUB)
label(code_ammo)
label(return_ammo)

newmem_ammo:
  // Template hook: block ammo decrement.
  jmp return_ammo

code_ammo:
  sub [rbx+00000198],eax
  jmp return_ammo

C3R_AMMO_SUB:
  jmp newmem_ammo
  nop
return_ammo:

[DISABLE]
C3R_AMMO_SUB:
  db 88 99 AA BB CC DD

dealloc(newmem_ammo)
      ]]></AssemblerScript>
      <Hotkeys>
