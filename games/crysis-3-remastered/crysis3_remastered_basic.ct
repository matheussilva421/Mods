    <CheatEntry>
      <ID>4</ID>
      <Description>"[F4] No Recoil (template)"</Description>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript><![CDATA[
[ENABLE]
aobscanmodule(C3R_RECOIL_WRITE,Crysis3Remastered.exe,10 20 30 40 50 60 70 80)
assert(C3R_RECOIL_WRITE,10 20 30 40 50 60 70 80)
alloc(newmem_recoil,$1000,C3R_RECOIL_WRITE)
label(code_recoil)
label(return_recoil)

newmem_recoil:
  // Template hook: zero recoil value before write.
  xorps xmm0,xmm0
  movss [rdi+000000D0],xmm0
  jmp return_recoil

code_recoil:
  movss [rdi+000000D0],xmm0
  jmp return_recoil

C3R_RECOIL_WRITE:
  jmp newmem_recoil
  nop
  nop
  nop
return_recoil:

[DISABLE]
C3R_RECOIL_WRITE:
  db 10 20 30 40 50 60 70 80

dealloc(newmem_recoil)
      ]]></AssemblerScript>
      <Hotkeys>
        <Hotkey>
          <Action>Toggle Activation</Action>
          <Keys>
            <Key>115</Key>
          </Keys>
          <ID>3</ID>
        </Hotkey>
      </Hotkeys>
    </CheatEntry>
    <CheatEntry>
      <ID>5</ID>
