# SteamTinkerLaunch — variaveis de ambiente para Crysis 3 Remastered
# Copie os valores relevantes para os campos de env/comando customizado do STL.

# Caminho para o binario do Cheat Engine (se nao estiver no PATH)
CE_BIN=cheatengine-x86_64

# Caminho absoluto para a tabela Cheat Engine
TABLE_PATH=/home/deck/tools/crysis-3-remastered-trainer/crysis3_remastered_basic.ct

# Arquivo de log do CE
LOG_FILE=/tmp/crysis3_remastered_ce.log

# Comando customizado STL (configure no campo "Custom Command" do STL):
# /home/deck/tools/crysis-3-remastered-trainer/steamdeck/stl_launch.sh %command%
