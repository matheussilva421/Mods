# SteamTinkerLaunch profile variables (example)
# Use this file as a reference and copy values into STL custom env/command fields.

# Full path to CE binary if not in PATH.
CE_BIN=cheatengine-x86_64

# Absolute path to your table file.
TABLE_PATH=/home/deck/tools/crysis3-remastered-trainer/crysis3_remastered_basic.ct

# CE log path.
LOG_FILE=/tmp/crysis3_remastered_ce.log

# STL custom command should point to:
# /home/deck/tools/crysis3-remastered-trainer/steamdeck/stl_launch.sh %command%
